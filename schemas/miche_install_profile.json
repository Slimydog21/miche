{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://miche.local/schemas/miche_install_profile.json",
  "title": "MicheInstallProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile_id", "apps", "secrets_path"],
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "apps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0,
      "uniqueItems": true
    },
    "secrets_path": {
      "type": "string",
      "minLength": 1
    }
  }
}